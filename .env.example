# PostgreSQL connection
DATABASE_URL="postgresql://wt:wt@localhost:5432/wedding_ticketing?schema=public"

# Auth.js (NextAuth v5) — generate with: openssl rand -base64 32
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# Google OAuth credentials (from Google Cloud Console).
# Leave blank locally if you use the dev email login below.
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Dev-only: when "true" (and NODE_ENV != production), enables a passwordless
# email login for any allowlisted user, so you can test without Google OAuth.
DEV_AUTH_ENABLED="true"
